IPA_BASE=https://api.jobsitex.co/api/v1
SOCKET_URL=https://api.jobsitex.co
API_TIMEOUT=10000
ENVIRONMENT=development

# Auth endpoints
LOGIN=/auth/login
REGISTER=/auth/signup
CHANGE_PASSWORD=/auth/change-password
OTP_AUTH=/auth/verify-otp
FORGOT_PASSWORD=/auth/forgot-password
RESET_PASSWORD=/auth/reset-password
REFRESH_TOKEN=/auth/refresh

# User endpoints
PROFILE_DETAILS=/user/profile
CHANGE_PROFILE=/user/profile

# Driver endpoints
DRIVER_DETAILS=/driver/profile
PROFILE_UPDATE=/driver/profile/complete
STATUS_DRIVER=/driver/availability
LOCATION_UPDATE=/driver/location
IMAGE_UPLOAD=/driver/profile/complete

# Job endpoints (all relative to IPA_BASE, append /:id where needed)
ALL_JOBS=/jobs/driver-jobs
JOB_DETAILS=/jobs/
ACCEPT_JOBS=/jobs/
START_JOBS=/jobs/
CANCEL_JOBS=/jobs/
COMPLETE_RIDE=/jobs/
ACTIVE_JOBS_USER=/jobs/my-jobs
ACCEPT_ALL_JOBS=/jobs/driver-jobs
COMPLETE_JOBS=/jobs/driver-jobs

